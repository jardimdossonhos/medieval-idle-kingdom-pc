{
  "name": "epochs-idle-pc",
  "version": "0.1.0",
  "private": true,
  "description": "Grand strategy idle local-first com mapa mundial e simulação sistêmica.",
  "author": "Josias Michel <josiasmichel@gmail.com>",
  "type": "module",
  "main": "desktop/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "map:build": "node scripts/generate-world-geojson.mjs",
    "desktop": "electron .",
    "desktop:run": "npm run build && electron .",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:dist": "npm run build && electron-builder --win portable nsis"
  },
  "dependencies": {
    "idb": "^8.0.2",
    "maplibre-gl": "^5.11.0",
    "pixi.js": "^8.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@turf/turf": "^7.3.4",
    "@types/node": "^22.13.9",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "geojson-vt": "^4.0.2",
    "topojson-client": "^3.1.0",
    "topojson-server": "^3.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.8",
    "vt-pbf": "^3.1.3",
    "world-atlas": "^2.0.2"
  },
  "build": {
    "appId": "com.jardimdossonhos.epochsidlepc",
    "productName": "Epochs Idle PC",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable",
        "nsis"
      ]
    }
  }
}
