{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "module":  "ESNext",
                            "moduleResolution":  "Bundler",
                            "lib":  [
                                        "ES2022",
                                        "DOM",
                                        "DOM.Iterable"
                                    ],
                            "strict":  true,
                            "noImplicitOverride":  true,
                            "noUnusedLocals":  true,
                            "noUnusedParameters":  true,
                            "noFallthroughCasesInSwitch":  true,
                            "resolveJsonModule":  true,
                            "allowSyntheticDefaultImports":  true,
                            "esModuleInterop":  true,
                            "isolatedModules":  true,
                            "skipLibCheck":  true,
                            "types":  [
                                          "vite/client",
                                          "vitest/globals"
                                      ],
                            "noEmit":  true
                        },
    "include":  [
                    "src",
                    "vite.config.ts",
                    "tests"
                ]
}